# SQL Server / Prisma
DATABASE_URL="sqlserver://localhost:1433;database=eccomers;user=YOUR_DB_USER;password=YOUR_DB_PASSWORD;trustServerCertificate=true;encrypt=true"
DB_HOST="localhost"
DB_PORT="1433"
DB_NAME="eccomers"
DB_USER="YOUR_DB_USER"
DB_PASSWORD="YOUR_DB_PASSWORD"
DB_ENCRYPT="true"
DB_TRUST_SERVER_CERT="true"

# API
HOST="0.0.0.0"
PORT="3000"
NODE_ENV="development"

# Auth
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN_SECONDS="604800"

# Seed
SEED_ADMIN_PASSWORD="replace-admin-password"

# Business config
CRC_REFERENCE_RATE="540"
CRC_ROUNDING="100"
CREDIT_REMINDER_INTERVAL_HOURS="6"
CREDIT_REMINDER_DAYS_BEFORE="3"

# SMTP (optional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Moonfit <noreply@example.com>"

# OpenAI image enhancement (optional)
OPENAI_API_KEY=""
OPENAI_IMAGE_MODEL="gpt-image-1.5"
